{
  "name": "@interview/source",
  "private": true,
  "scripts": {
    "build": "nx run-many --target=build --all",
    "build:service": "nx run $SERVICE:build",
    "start": "nx run-many --target=serve --all",
    "start:service": "nx run $SERVICE:serve",
    "start:dev": "nx run $SERVICE:serve:development",
    "lint": "nx run-many --target=lint --all",
    "lint:service": "nx run $SERVICE:lint",
    "lint:fix": "nx run-many --target=lint --all -- --fix",
    "test": "nx run-many --target=test --all",
    "test:service": "nx run $SERVICE:test",
    "localstack:up": "docker compose -f docker/docker-compose.localstack.yml up -d",
    "localstack:down": "docker compose -f docker/docker-compose.localstack.yml down",
    "localstack:deploy": "bash scripts/setup-localstack.sh",
    "localstack:destroy": "AWS_ACCESS_KEY_ID=test AWS_SECRET_ACCESS_KEY=test AWS_DEFAULT_REGION=us-east-1 aws --endpoint-url=http://localhost:4566 dynamodb delete-table --table-name jobs 2>/dev/null; AWS_ACCESS_KEY_ID=test AWS_SECRET_ACCESS_KEY=test AWS_DEFAULT_REGION=us-east-1 aws --endpoint-url=http://localhost:4566 s3 rb s3://job-execution-files --force 2>/dev/null; echo done",
    "cdk:bootstrap": "cd infra && npm run build && npx cdk bootstrap",
    "cdk:deploy": "cd infra && npm run build && npx cdk deploy --require-approval never",
    "cdk:destroy": "cd infra && npx cdk destroy --force",
    "cdk:diff": "cd infra && npm run build && npx cdk diff"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-ssm": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "nestjs-pino": "^4.4.0",
    "pino": "^9.9.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nx/devkit": "^21.0.0",
    "@nx/eslint": "^21.0.0",
    "@nx/eslint-plugin": "^22.7.5",
    "@nx/jest": "^21.0.0",
    "@nx/js": "^21.0.0",
    "@nx/nest": "^21.0.0",
    "@nx/webpack": "^21.0.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.11.29",
    "@swc/helpers": "^0.5.23",
    "swc-loader": "^0.2.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.4.2",
    "jsonc-eslint-parser": "^3.1.0",
    "nodemon": "^3.1.14",
    "nx": "^21.0.0",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "swc-loader": "^0.2.7",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.61.0"
  }
}
